#!/command/with-contenv bashio
bashio::log.info "PA: PulseAudio shutting down — unloading modules..."

export PULSE_SERVER="unix:/run/pulse/native"

pactl unload-module module-always-sink          2>/dev/null || true
pactl unload-module module-null-sink            2>/dev/null || true
pactl unload-module module-native-protocol-unix 2>/dev/null || true

rm -f /run/pulse/native
bashio::log.info "PA: PulseAudio cleanup done."
